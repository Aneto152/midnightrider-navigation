  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 2
      },
      "options": {
        "mode": "markdown",
        "content": "# ⚓ Midnight Rider — Data Model Status\n_Statut opérationnel en temps réel. **🟢 ACTIVE** = données < 30s. **🟡 STALE** = données entre 30s et 5min. **🔴 NO DATA** = aucune donnée depuis 5min._"
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "🛠️ SERVICES — Signal K + InfluxDB",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 2,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Signal K API",
      "description": "Signal K natif (systemd)\n📐 navigation.speedOverGround",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 4,
        "h": 3
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "noValue": "❌ NO DATA",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.4
              },
              {
                "color": "green",
                "value": 0.9
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0.5": {
                  "text": "⚠️ STALE",
                  "color": "orange"
                },
                "1": {
                  "text": "✅ ACTIVE",
                  "color": "green"
                }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "❌ NO DATA",
                  "color": "red"
                }
              }
            }
          ]
        }
      },
      "datasource": {
        "type": "influxdb",
        "uid": "efifgp8jvgj5sf"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "efifgp8jvgj5sf"
          },
          "query": "from(bucket:\"midnight_rider\")\n |> range(start: -5m)\n |> filter(fn: (r) => r._measurement == \"navigation.speedOverGround\" and r._field != \"lat\" and r._field != \"lon\")\n |> aggregateWindow(every: 30s, fn: count, createEmpty: true)\n |> last()\n |> map(fn: (r) => ({r with _value: if r._value > 0 then 1.0 else 0.5}))"
        }
      ]
    },
