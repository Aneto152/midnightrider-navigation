# Midnight Rider — Configuration Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git

# ============================================================
# GRAFANA
# ============================================================
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
GRAFANA_TOKEN=your_grafana_service_account_token_here
GRAFANA_DATASOURCE_ID=5

# ============================================================
# INFLUXDB
# ============================================================
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_influxdb_token_here
INFLUX_ORG=MidnightRider
INFLUX_BUCKET=midnight_rider

# Cloud InfluxDB (optional, for data replication)
INFLUX_CLOUD_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_CLOUD_TOKEN=your_influxdb_cloud_token_here
INFLUX_CLOUD_ORG=your_cloud_org_id

# ============================================================
# SIGNAL K
# ============================================================
SIGNALK_URL=http://localhost:3000
SIGNALK_API_TOKEN=your_signalk_api_token_here

# ============================================================
# WHATSAPP / TWILIO (Media Man Reporter)
# ============================================================
# Twilio Account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# WhatsApp Business
WHATSAPP_PHONE_FROM=+14155238886
WHATSAPP_GROUP_BLOCK_ISLAND_2026=120363196789012345@g.us

# Additional groups (future races)
WHATSAPP_GROUP_ETAPE_3_2026=120363196789012346@g.us
WHATSAPP_GROUP_COUPE_AUTOMNE_2026=120363196789012347@g.us

# ============================================================
# RACE CONFIGURATION
# ============================================================
RACE_NAME=Block Island Race 2026
BOAT_NAME=Midnight Rider
BOAT_CLASS=J/30
SKIPPER_NAME=Denis Lafarge

# ============================================================
# MEDIA MAN (Race Reporter)
# ============================================================
REPORTER_ENABLED=true
REPORTER_INTERVAL_MIN=30
WIND_ALERT_KT=25
SPEED_RECORD_THRESHOLD_KT=0.5
POSITION_UPDATE_INTERVAL_MIN=30

# ============================================================
# BATTERY (SOK BMS)
# ============================================================
SOK_BMS_ENABLED=false
SOK_BMS_MAC_ADDRESS=XX:XX:XX:XX:XX:XX
SOK_BMS_ALERT_LOW_SOC_PCT=10
SOK_BMS_ALERT_HIGH_TEMP_C=45
SOK_BMS_ALERT_CELL_IMBALANCE_MV=100

# ============================================================
# LOGGING & DEBUG
# ============================================================
LOG_LEVEL=INFO
DEBUG_MODE=false

# ============================================================
# DOCKER
# ============================================================
COMPOSE_PROJECT_NAME=midnight-rider

# ============================================================
# CLOUD INTEGRATION (Post-Race Sync)
# ============================================================
# InfluxDB Cloud credentials (for data replication after race)
INFLUX_CLOUD_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_CLOUD_ORG=your-cloud-org-name
INFLUX_CLOUD_ORG_ID=your-cloud-org-id
INFLUX_CLOUD_TOKEN=your-cloud-write-read-token
INFLUX_CLOUD_BUCKET=midnight_rider

# Grafana Cloud (for dashboard access from web)
GRAFANA_CLOUD_URL=https://yourstack.grafana.net
GRAFANA_CLOUD_API_KEY=your-grafana-cloud-api-key

# Google Drive backup (rclone remote name)
GDRIVE_REMOTE=gdrive
GDRIVE_PATH=MidnightRider/InfluxDB-backups
