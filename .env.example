# Environment Variables — Midnight Rider Navigation System
# 
# SECURITY: Copy this file to .env and fill in REAL values.
# DO NOT commit .env to git — it's gitignored for security.
#
# Generated: 2026-04-25
# Status: All secrets must be set via environment variables, not hardcoded

# InfluxDB Authentication
# Get token from: docker exec influxdb influx auth list
# OR: InfluxDB admin UI http://localhost:8086
INFLUX_TOKEN=<your-new-token-here>
INFLUX_ORG=MidnightRider
INFLUX_BUCKET=signalk
INFLUX_URL=http://localhost:8086

# Optional: Cloud InfluxDB (if using cloud instead of local)
# INFLUX_URL=https://cloud.influxdata.com
# INFLUX_ORG=<your-cloud-org>
# INFLUX_BUCKET=<your-cloud-bucket>
# INFLUX_TOKEN=<your-cloud-token>

# Signal K API
SIGNALK_URL=http://localhost:3000
SIGNALK_PORT=3000

# Grafana (optional)
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_PASSWORD=admin

# NOAA/Weather APIs (optional)
NOAA_API_TIMEOUT=10
OPEN_METEO_API=https://api.open-meteo.com/v1

# Development
DEBUG=false
LOG_LEVEL=info
