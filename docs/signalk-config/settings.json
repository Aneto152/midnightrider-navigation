{
  "plugins": {
    "@tkurki/um982": {
      "enabled": false,
      "serialconnection": "/dev/ttyUSB0",
      "ntripEnabled": false
    },
    "signalk-um982-proprietary": {
      "enabled": false
    },
    "signalk-gps-um982-nmea-parser": {
      "enabled": false
    },
    "signalk-wit-imu-ble": {
      "enabled": true,
      "bleAddress": "E9:10:DB:8B:CE:C7",
      "bleName": "WT901BLE68",
      "autoReconnect": true,
      "enableAcceleration": true,
      "enableRateOfTurn": true
    },
    "signalk-um982-custom": {
      "enabled": true,
      "serialPort": "/dev/ttyUSB0",
      "baudRate": 115200
    },
    "signalk-to-nmea0183": {
      "enabled": true
    },
    "position-combiner": {
      "enabled": true
    },
    "signalk-wave-analyzer": {
      "enabled": true,
      "accelPath": "navigation.acceleration.z",
      "sampleRateHz": 30,
      "windowMinutes": 10,
      "outputIntervalSeconds": 5,
      "hpCutoffHz": 0.05
    }
  },
  "pipedProviders": [
    {
      "id": "Calypso",
      "enabled": true,
      "pipeElements": [
        {
          "type": "providers/simple",
          "options": {
            "logging": false,
            "type": "SignalK",
            "subOptions": {
              "type": "udp",
              "port": "4123",
              "selfHandling": "noSelf"
            }
          }
        }
      ]
    },
    {
      "id": "qtVLM-NMEA-Input",
      "enabled": true,
      "pipeElements": [
        {
          "type": "providers/tcp",
          "options": {
            "host": "127.0.0.1",
            "port": "10111"
          }
        },
        {
          "type": "providers/nmea0183-signalk",
          "optionMappings": [
            {
              "fromAppProperty": "selfId",
              "toOption": "selfId"
            }
          ]
        }
      ]
    }
  ],
  "interfaces": {
    "udp": {
      "4123": {
        "type": "signalk-udp-input",
        "enabled": true,
        "class": "SignalK"
      }
    },
    "tcp": {
      "10111": {
        "type": "signalk-nmea-0183-input",
        "enabled": true,
        "class": "NMEA0183"
      }
    },
    "nmea-tcp": {
      "10110": {
        "enabled": true,
        "port": 10110
      }
    }
  },
  "resourcesApi": {
    "defaultProviders": {
      "routes": "resources-provider",
      "waypoints": "resources-provider",
      "regions": "resources-provider",
      "notes": "resources-provider",
      "charts": "resources-provider"
    }
  },
  "courseApi": {
    "apiOnly": false
  }
}